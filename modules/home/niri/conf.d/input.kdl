// 输入设备:键盘/触控板/鼠标配置

input {
    // 键盘：系统默认布局 + 启动时点亮 NumLock + 按住方向键连续移动
    keyboard {
        xkb {}
        numlock
        repeat-delay 300
        repeat-rate 30
    }
    // 触控板：轻触点击 + 自然滚动方向
    touchpad {
        tap
        natural-scroll
    }
    // 鼠标：加速度 0（默认，轻快跟手）
    mouse {
        accel-speed 0.0
    }
}
