// 应用专属窗口规则
// 针对特定软件的个性化设置

// ===== 桌面组件 =====
window-rule {
    match app-id=r#"dev.noctalia.Noctalia"#
    open-floating true
}

// ===== 文件管理器 =====
window-rule {
    match app-id="org.xfce.thunar"
    open-floating true
    opacity 0.5
    geometry-corner-radius 12
    clip-to-geometry true
    draw-border-with-background false
    background-effect {
        blur true
        xray true
    }
}

// ===== Brave 浏览器通用窗口 =====
// 只保留圆角裁剪，聚焦环由 Niri 全局控制
window-rule {
    match app-id="brave-browser"
    clip-to-geometry true
}

// ===== 画中画模式 =====
window-rule {
    match app-id="brave-browser" title="画中画"
    match app-id="brave-browser" title="Picture-in-Picture"

    open-floating true
    opacity 1.0
    default-column-width {}
    default-window-height {}
    default-floating-position x=20 y=20 relative-to="bottom-right"
}

